│                                                                              │
│              # Keep only last 10 readings                                    │
│              PROCESS_MEMORY_HISTORY = PROCESS_MEMORY_HISTORY[-10:]           │
│                                                                              │
│              # Check for consistent growth                                   │
│              if len(PROCESS_MEMORY_HISTORY) > 3:                             │
│                  growth = (mem - PROCESS_MEMORY_HISTORY[0][1]) / (1024 *     │
